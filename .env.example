# Configuración de la Base de Datos PostgreSQL
# Ejemplo: postgresql://usuario:contraseña@host:puerto/nombre_bd
DATABASE_URL=

# Secreto para firmar los tokens JWT (puedes poner cualquier cadena de texto segura)
JWT_SECRET=super-secret-key-123

# Clave de la API de Gemini (ya configurada por el entorno)
GEMINI_API_KEY=
